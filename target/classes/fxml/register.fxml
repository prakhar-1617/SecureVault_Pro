<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="550.0" prefWidth="750.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.securevault.ui.RegisterController">
    <stylesheets>
        <URL value="@../styles/dark-theme.css" />
    </stylesheets>
    
    <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <children>
            <VBox alignment="CENTER" maxWidth="420.0" spacing="20.0" styleClass="glass-panel">
                <padding>
                    <Insets bottom="35.0" left="40.0" right="40.0" top="35.0" />
                </padding>
                <children>
                    <VBox alignment="CENTER" spacing="5.0">
                        <children>
                            <Label styleClass="label-title" text="Create Account" />
                            <Label styleClass="label-subtitle" text="Register a secure master key profile" />
                        </children>
                    </VBox>
                    
                    <VBox spacing="12.0">
                        <children>
                            <VBox spacing="4.0">
                                <children>
                                    <Label styleClass="label-subtitle" text="USERNAME" />
                                    <TextField fx:id="usernameField" promptText="Choose a username" />
                                </children>
                            </VBox>
                            
                            <VBox spacing="4.0">
                                <children>
                                    <Label styleClass="label-subtitle" text="MASTER PASSWORD" />
                                    <PasswordField fx:id="passwordField" promptText="Enter strong password" />
                                </children>
                            </VBox>
                            
                            <VBox spacing="4.0">
                                <children>
                                    <Label styleClass="label-subtitle" text="CONFIRM PASSWORD" />
                                    <PasswordField fx:id="confirmPasswordField" promptText="Re-type password" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                    
                    <VBox style="-fx-background-color: rgba(255, 255, 255, 0.03); -fx-background-radius: 6px; -fx-padding: 10;" spacing="3.0">
                        <children>
                            <Label style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #a78bfa;" text="PASSWORD REQUIREMENTS:" />
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;" text="• At least 8 characters in length" />
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;" text="• Contain at least one uppercase letter" />
                            <Label style="-fx-font-size: 11px; -fx-text-fill: #9ca3af;" text="• Contain at least one digit and one special character" />
                        </children>
                    </VBox>
                    
                    <Label fx:id="errorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 13px;" wrapText="true" />
                    
                    <VBox alignment="CENTER" spacing="12.0">
                        <children>
                            <Button fx:id="registerButton" defaultButton="true" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#handleRegister" styleClass="btn-primary" text="Register" />
                            <Button mnemonicParsing="false" onAction="#showLogin" styleClass="btn-link" text="Already have an account? Log In" />
                        </children>
                    </VBox>
                </children>
            </VBox>
        </children>
    </VBox>
</AnchorPane>
