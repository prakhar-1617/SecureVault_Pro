<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.securevault.ui.VaultController">
    <children>
        <!-- Header -->
        <VBox spacing="5.0">
            <children>
                <Label styleClass="label-header" text="Secure Password Vault" />
                <Label styleClass="label-subtitle" text="Credentials are encrypted in-memory using an AES key derived from your master password." />
            </children>
        </VBox>
        
        <!-- Main Layout Split -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                
                <!-- Credentials Table & Search (Left side) -->
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <TextField fx:id="searchField" promptText="Search by website or username..." HBox.hgrow="ALWAYS" />
                                <Button mnemonicParsing="false" onAction="#handleSearch" styleClass="btn-secondary" text="Search" />
                                <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-secondary" text="Reset" />
                            </children>
                        </HBox>
                        
                        <TableView fx:id="credentialsTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="idCol" prefWidth="50.0" text="ID" />
                                <TableColumn fx:id="websiteCol" prefWidth="180.0" text="Website / App" />
                                <TableColumn fx:id="usernameCol" prefWidth="150.0" text="Username" />
                                <TableColumn fx:id="passwordCol" prefWidth="120.0" text="Password" />
                                <TableColumn fx:id="modifiedCol" prefWidth="140.0" text="Last Modified" />
                            </columns>
                        </TableView>
                        
                        <HBox spacing="10.0">
                            <children>
                                <Button fx:id="showPasswordBtn" mnemonicParsing="false" onAction="#handleShowPassword" styleClass="btn-primary" text="👁 Show Password" />
                                <Button fx:id="deleteBtn" mnemonicParsing="false" onAction="#handleDeleteCredential" styleClass="btn-secondary" style="-fx-text-fill: #ef4444;" text="🗑 Delete Selected" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                
                <!-- Add/Edit Form Panel (Right side) -->
                <VBox prefWidth="320.0" spacing="15.0" styleClass="glass-panel">
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                    <children>
                        <Label fx:id="formTitleLabel" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Add New Credential" />
                        
                        <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                            <children>
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="label-subtitle" text="WEBSITE / SERVICE" />
                                        <TextField fx:id="websiteField" promptText="e.g. google.com" />
                                    </children>
                                </VBox>
                                
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="label-subtitle" text="USERNAME / EMAIL" />
                                        <TextField fx:id="usernameField" promptText="e.g. john@example.com" />
                                    </children>
                                </VBox>
                                
                                <VBox spacing="4.0">
                                    <children>
                                        <Label styleClass="label-subtitle" text="PASSWORD" />
                                        <TextField fx:id="passwordField" promptText="Enter password" />
                                    </children>
                                </VBox>
                                
                                <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                                    <children>
                                        <Label styleClass="label-subtitle" text="NOTES" />
                                        <TextArea fx:id="notesField" prefHeight="100.0" promptText="Add optional notes..." wrapText="true" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>
                        
                        <Label fx:id="formErrorLabel" style="-fx-text-fill: #ef4444; -fx-font-size: 11px;" wrapText="true" />
                        
                        <HBox spacing="10.0">
                            <children>
                                <Button fx:id="saveBtn" mnemonicParsing="false" onAction="#handleSaveCredential" styleClass="btn-primary" text="Save" HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" />
                                <Button fx:id="clearBtn" mnemonicParsing="false" onAction="#handleClearForm" styleClass="btn-secondary" text="Clear" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
                
            </children>
        </HBox>
    </children>
</VBox>
