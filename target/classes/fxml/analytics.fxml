<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.securevault.ui.AnalyticsDashboardController">
    <children>
        <!-- Header -->
        <HBox alignment="CENTER_LEFT">
            <children>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label styleClass="label-header" text="System Performance &amp; Cryptographic Analytics" />
                        <Label styleClass="label-subtitle" text="Real-time monitoring of encryption latency, cache hits, and thread pool efficiency." />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-primary" text="🔄 Refresh Stats" />
            </children>
        </HBox>
        
        <!-- Metric Cards Grid -->
        <GridPane hgap="15.0" vgap="15.0">
            <columnConstraints>
                <!-- 4 columns of equal size -->
                <javafx.scene.layout.ColumnConstraints percentWidth="25.0" />
                <javafx.scene.layout.ColumnConstraints percentWidth="25.0" />
                <javafx.scene.layout.ColumnConstraints percentWidth="25.0" />
                <javafx.scene.layout.ColumnConstraints percentWidth="25.0" />
            </columnConstraints>
            <rowConstraints>
                <javafx.scene.layout.RowConstraints minHeight="80.0" />
            </rowConstraints>
            <children>
                <!-- Card 1: Total Operations -->
                <VBox alignment="CENTER" styleClass="glass-panel" GridPane.columnIndex="0">
                    <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                    <children>
                        <Label styleClass="label-subtitle" text="TOTAL OPERATIONS" />
                        <Label fx:id="totalOpsLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;" text="0" />
                    </children>
                </VBox>
                
                <!-- Card 2: Avg Duration -->
                <VBox alignment="CENTER" styleClass="glass-panel" GridPane.columnIndex="1">
                    <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                    <children>
                        <Label styleClass="label-subtitle" text="AVG LATENCY" />
                        <Label fx:id="avgDurationLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #3b82f6;" text="0.0 ms" />
                    </children>
                </VBox>
                
                <!-- Card 3: Cache Hit Ratio -->
                <VBox alignment="CENTER" styleClass="glass-panel" GridPane.columnIndex="2">
                    <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                    <children>
                        <Label styleClass="label-subtitle" text="CACHE HIT RATIO" />
                        <Label fx:id="cacheRatioLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #10b981;" text="0.0%" />
                    </children>
                </VBox>
                
                <!-- Card 4: active threads -->
                <VBox alignment="CENTER" styleClass="glass-panel" GridPane.columnIndex="3">
                    <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
                    <children>
                        <Label styleClass="label-subtitle" text="ACTIVE THREADS" />
                        <Label fx:id="activeThreadsLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #06b6d4;" text="0" />
                    </children>
                </VBox>
            </children>
        </GridPane>
        
        <!-- Charts Row -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- Bar Chart: Latency by Algo -->
                <VBox spacing="10.0" styleClass="glass-panel" HBox.hgrow="ALWAYS">
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Average Encryption Latency by Algorithm" />
                        <BarChart fx:id="latencyChart" legendVisible="false" VBox.vgrow="ALWAYS">
                            <xAxis>
                                <CategoryAxis side="BOTTOM" fx:id="algoAxis" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Latency (ms)" side="LEFT" />
                            </yAxis>
                        </BarChart>
                    </children>
                </VBox>
                
                <!-- Pie Chart: Algorithm Usage Share -->
                <VBox spacing="10.0" styleClass="glass-panel" prefWidth="350.0">
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                    <children>
                        <Label style="-fx-font-weight: bold;" text="Algorithm Distribution" />
                        <PieChart fx:id="distributionChart" legendSide="BOTTOM" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
